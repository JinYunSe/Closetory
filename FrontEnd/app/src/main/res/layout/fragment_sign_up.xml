<?xml version="1.0" encoding="utf-8"?>

<!-- 회원가입 페이지 xml (id/변수명 유지, UI만 로그인 테마 스타일로 통일) -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    tools:layout_editor_absoluteX="20dp"
    tools:layout_editor_absoluteY="20dp">

    <!-- 타이틀: 로그인 화면 스타일로 통일 -->
    <TextView
        android:id="@+id/tvSignupTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="회원가입"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/main_color"
        android:layout_marginBottom="10dp" />

    <!-- 아이디 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        app:boxBackgroundMode="none"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSignupId"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_input"
            android:hint="아이디"
            android:singleLine="true"
            android:maxLines="1"
            android:inputType="text"
            android:textSize="@dimen/text_input"
            android:padding="1dp"
            android:textColor="@android:color/black"
            android:textColorHint="#9E9E9E" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 비밀번호(눈 아이콘 포함) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="@dimen/text_to_text">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSignupPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="비밀번호 (영문, 숫자, 특수문자, 8자 이상 필수)"
                android:inputType="textPassword"
                android:textSize="@dimen/text_input"
                android:padding="1dp"
                android:singleLine="true"
                android:maxLines="1"
                android:textColor="@android:color/black"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnTogglePassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_eye"
            android:contentDescription="비밀번호 보기/숨기기" />
    </FrameLayout>

    <!-- 비밀번호 확인(눈 아이콘 포함) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="@dimen/text_to_text">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSignupPasswordConfirmation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="비밀번호 확인"
                android:inputType="textPassword"
                android:textSize="@dimen/text_input"
                android:padding="1dp"
                android:singleLine="true"
                android:maxLines="1"
                android:textColor="@android:color/black"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnTogglePasswordConfirmation"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_eye"
            android:contentDescription="비밀번호 보기/숨기기" />
    </FrameLayout>

    <!-- 닉네임 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="@dimen/text_to_text"
        app:boxBackgroundMode="none"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSignupNickname"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_input"
            android:hint="닉네임 (특수문자 제외 10자 이하)"
            android:singleLine="true"
            android:maxLines="1"
            android:inputType="text"
            android:textSize="@dimen/text_input"
            android:maxLength="10"
            android:padding="1dp"
            android:textColor="@android:color/black"
            android:textColorHint="#9E9E9E"
            android:imeOptions="actionNext"
            android:nextFocusDown="@id/etPersonalHeight" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 키/몸무게 -->
    <LinearLayout
        android:id="@+id/personalSizeContainer"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="@dimen/text_to_text"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPersonalHeight"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="키(cm)"
                android:textSize="@dimen/text_input"
                android:singleLine="true"
                android:maxLines="1"
                android:maxLength="3"
                android:inputType="number"
                android:padding="1dp"
                android:textColor="@android:color/black"
                android:textColorHint="#9E9E9E"
                android:imeOptions="actionNext"
                android:nextFocusDown="@id/etPersonalWeight" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPersonalWeight"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="몸무게(kg)"
                android:singleLine="true"
                android:textSize="@dimen/text_input"
                android:maxLines="1"
                android:maxLength="3"
                android:inputType="number"
                android:padding="1dp"
                android:layout_weight="1"
                android:textColor="@android:color/black"
                android:textColorHint="#9E9E9E"
                android:imeOptions="actionNext"
                android:nextFocusDown="@id/btnFemale" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- 성별 -->
    <LinearLayout
        android:id="@+id/genderContainer"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="@dimen/text_to_text"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFemale"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="여성"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="@dimen/text_button"
            android:padding="4dp"
            app:rippleColor="@android:color/transparent"
            app:backgroundTint="@color/gray_300"
            app:cornerRadius="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMale"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="남성"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="@dimen/text_button"
            android:padding="4dp"
            app:rippleColor="@android:color/transparent"
            app:backgroundTint="@color/gray_300"
            app:cornerRadius="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>

    <!-- 알람 수신 여부 -->
    <LinearLayout
        android:id="@+id/alarmContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false" />

        <TextView
            android:id="@+id/tvAlarmTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="알람 수신 여부"
            android:textColor="#000000"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 회원가입 완료 버튼 -->

    <!-- 하단 링크 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignupOkay"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:padding="4dp"
        android:text="회원가입 완료"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="@color/main_color"
        app:cornerRadius="8dp"
        app:rippleColor="#66FFFFFF"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvYesId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="이미 계정이 있으신가요?"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvYesIdToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="로그인"
            android:textColor="#000000"
            android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>
