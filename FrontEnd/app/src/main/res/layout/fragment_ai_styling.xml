<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    tools:context=".homeActivity.aiStyling.AiStylingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.7"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="4dp">

            <!--   파란 글씨(여기만 바뀌게)   -->
            <TextView
                android:id="@+id/tv_style_mode"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="어울림"
                android:textColor="#000000"
                android:textSize="12sp"/>

            <!--   스위치에는 글자 절대 표시 X   -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_style_mode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center|start"
                android:showText="false"
                android:scaleX="0.80"
                android:scaleY="0.80"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:switchMinWidth="0dp"
                android:switchPadding="0dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.7"
            android:layout_marginEnd="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="6dp">

            <!--   파란 글씨(여기만 바뀌게)   -->
            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="모든 옷"
                android:textColor="#000000"
                android:textSize="12sp"/>

            <!--   스위치에는 글자 절대 표시 X   -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center|start"
                android:showText="false"
                android:scaleX="0.80"
                android:scaleY="0.80"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:switchMinWidth="0dp"
                android:switchPadding="0dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector"/>

        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="47dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_makeoutfit"
                android:layout_width="match_parent"
                android:layout_height="47dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:insetTop="0dp"
                android:insetBottom="0dp"

                android:elevation="0dp"
                android:translationZ="0dp"
                android:stateListAnimator="@null"

                android:text="직접 코디"
                android:textColor="#000000"
                app:icon="@drawable/img_direct_coordination"
                app:iconTint="@color/black"
                app:iconSize="18dp"
                app:iconGravity="textStart"/>

        </FrameLayout>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_login_input">

        <!--  기존 슬롯 레이아웃  -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center">

            <!--  상의 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

            <!--  아우터 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside"/>

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

            <!--  악세서리 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside"/>

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

            <!--  하의 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside"/>

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

            <!--  가방 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside"/>

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

            <!--  신발 슬롯  -->
            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="85dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside"/>

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone"/>

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--  AI 추천 로딩 애니메이션 (슬롯 영역 중앙)  -->
        <VideoView
            android:id="@+id/vv_ai_loading"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!--  가상피팅 결과 팝업  -->
        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/gray_500"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="AI 가상 피팅 결과"
                android:scaleType="centerInside"/>

            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="닫기"
                android:src="@drawable/ic_cancel"/>

            <!--  AI 가상피팅 로딩 애니메이션  -->
            <VideoView
                android:id="@+id/vv_ai_fitting"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:visibility="gone"/>

        </FrameLayout>

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <ImageView
            android:id="@+id/iv_ai_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginBottom="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_ai" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sv_ai_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:maxHeight="180dp"
            android:overScrollMode="never">

            <TextView
                android:id="@+id/tv_ai_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/speech_bubble"
                android:letterSpacing="-0.01"
                android:lineSpacingExtra="4dp"
                android:minHeight="64dp"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp"
                android:text="'AI 코디추천'을 눌러보세요.\n\n무신사 스타일로 여러분의 코디를 추천해드립니다!"
                android:textColor="#000000"
                android:textSize="14.5sp" />

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!--   등록 버튼   -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="AI 코디추천"
                android:background="@drawable/bg_login_button_black"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                app:icon="@drawable/img_ai_logo"
                app:iconSize="18dp"
                app:iconGravity="textStart"/>

        </FrameLayout>

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_styling_reset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input"
            app:backgroundTint="@null"
            android:text="초기화"
            android:textColor="#000000"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"

            android:elevation="0dp"
            android:translationZ="0dp"
            android:stateListAnimator="@null"
            />

    </LinearLayout>

</LinearLayout>
