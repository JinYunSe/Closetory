<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".homeActivity.aiStyling.AiStylingFragment">

    <!-- 상단 토글/버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- 스타일 모드 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input_stronger"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <TextView
                android:id="@+id/tv_style_mode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:singleLine="true"
                android:text="어울림"
                android:textColor="@color/gray_500"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_style_mode"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:scaleX="0.85"
                android:scaleY="0.85"
                android:showText="false" />
        </LinearLayout>

        <View
            android:layout_width="10dp"
            android:layout_height="match_parent" />

        <!-- 내 옷만 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input_stronger"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:singleLine="true"
                android:text="모든 옷"
                android:textColor="@color/gray_500"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:scaleX="0.85"
                android:scaleY="0.85"
                android:showText="false" />
        </LinearLayout>

        <View
            android:layout_width="10dp"
            android:layout_height="match_parent" />

        <!-- 직접 코디 생성 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_makeoutfit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input_stronger"
            android:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingVertical="0dp"
            android:text="직접코디\n생성"
            android:textColor="@color/gray_500"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:strokeWidth="0dp" />
    </LinearLayout>

    <!-- ✅ 가운데 슬롯 영역: 고정 500dp 제거 → 남는 공간만큼만 차지 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/bg_login_input_stronger"
        android:padding="12dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 상의 -->
            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 아우터 -->
            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:layout_marginEnd="14dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top"
                app:layout_constraintBottom_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 악세서리 -->
            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginStart="14dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top"
                app:layout_constraintBottom_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 하의 -->
            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@+id/slot_top"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 가방 -->
            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="98dp"
                android:layout_height="98dp"
                android:layout_marginStart="14dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom"
                app:layout_constraintBottom_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 신발 -->
            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="98dp"
                android:layout_height="98dp"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- AI 추천 로딩 -->
        <VideoView
            android:id="@+id/vv_ai_loading"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- 가상피팅 결과 팝업 -->
        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/gray_500"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="AI 가상 피팅 결과"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="닫기"
                android:src="@drawable/ic_cancel" />

            <VideoView
                android:id="@+id/vv_ai_fitting"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>
    </FrameLayout>

    <!-- 말풍선 영역: ✅ 최대 높이 제한 + 스크롤 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <ImageView
            android:id="@+id/iv_ai_profile"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginBottom="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/default_image" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:maxHeight="110dp"
                android:overScrollMode="never">

                <TextView
                    android:id="@+id/tv_ai_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/speech_bubble_left"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="44dp"
                    android:paddingStart="20dp"
                    android:paddingTop="26dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="AI가 여기에 답변을 해줍니다."
                    android:textColor="#333333"
                    android:textSize="14sp" />
            </ScrollView>
        </FrameLayout>
    </LinearLayout>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="✨AI 코디추천"
            android:textColor="@color/white"
            app:cornerRadius="10dp" />

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_styling_reset"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input_stronger"
            app:backgroundTint="@color/gray_300"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="초기화"
            android:textColor="@color/main_color"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
