<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingBottom="16dp"
    tools:context=".homeActivity.aiStyling.AiStylingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_switch_group"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">
            <!--  파란 글씨(여기만 바뀌게)  -->
            <TextView
                android:id="@+id/tv_style_mode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:text="어울림"
                android:textColor="#A6DAF4"
                android:textSize="14sp" />
            <!--  스위치에는 글자 절대 표시 X  -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_style_mode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:gravity="center"
                android:showText="false"
                android:switchMinWidth="48dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_switch_group"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">
            <!--  파란 글씨(여기만 바뀌게)  -->
            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:text="모든 옷"
                android:textColor="#A6DAF4"
                android:textSize="14sp" />
            <!--  스위치에는 글자 절대 표시 X  -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:gravity="center"
                android:showText="false"
                android:switchMinWidth="48dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_makeoutfit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingVertical="0dp"
            android:text="직접코디\n생성"
            android:textColor="#A6DAF4"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="12dp"
            app:strokeColor="#A6DAF4"
            app:strokeWidth="0.8dp" />
    </LinearLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#e9ecef">

        <!-- 기존 슬롯 레이아웃 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 상의 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 아우터 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 악세서리 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 하의 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 가방 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 신발 슬롯 -->
            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- AI 추천 로딩 애니메이션 (슬롯 영역 중앙) -->
        <VideoView
            android:id="@+id/vv_ai_loading"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- 가상피팅 결과 팝업 -->
        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/gray_500"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="AI 가상 피팅 결과"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="닫기"
                android:src="@drawable/ic_cancel" />

            <!-- AI 가상피팅 로딩 애니메이션 -->
            <VideoView
                android:id="@+id/vv_ai_fitting"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:visibility="gone" />

        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/iv_ai_profile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/default_image" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sv_ai_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:maxHeight="150dp"
            android:overScrollMode="never">

            <TextView
                android:id="@+id/tv_ai_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/speech_bubble_left"
                android:lineSpacingExtra="4dp"
                android:minHeight="44dp"
                android:paddingStart="20dp"
                android:paddingTop="30dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:text="AI가 여기에 답변을 해줍니다. 텍스트가 길어지면 자동으로 위로 늘어나며 스크롤이 생성됩니다."
                android:textColor="#333333"
                android:textSize="14sp" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <!--  등록 버튼  -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="✨AI 코디추천"
                android:background="@drawable/bg_aicodybutton"
                android:textColor="@android:color/white"
                app:backgroundTint="@null"
                app:cornerRadius="12dp" />

        </FrameLayout>

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_styling_reset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:backgroundTint="#FFFFFF"
            android:text="초기화"
            android:textColor="@color/main_color"
            app:cornerRadius="12dp"
            app:strokeColor="@color/main_color"
            app:strokeWidth="1dp"/>
    </LinearLayout>
</LinearLayout>