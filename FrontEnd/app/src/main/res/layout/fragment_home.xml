<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".homeActivity.home.HomeFragment">

    <!-- 화면을 비율로 나누는 가이드라인 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideCalendarBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <!-- 캘린더 (id 유지) -->
    <include
        android:id="@+id/home_calender"
        layout="@layout/dialog_calendar_picker"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideCalendarBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 섹션 헤더: 스레드 / 더보기 (id 유지) -->
    <TextView
        android:id="@+id/btn_posts_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:text="쓰레드"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/main_color"
        app:layout_constraintTop_toTopOf="@id/guideCalendarBottom"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/btn_posts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:text="더보기"
        android:textColor="@color/main_color"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/rv_posts"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 게시글 리스트 (id 유지) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_posts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:nestedScrollingEnabled="true"
        tools:listitem="@layout/item_post_card"
        app:layout_constraintTop_toBottomOf="@id/btn_posts_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>