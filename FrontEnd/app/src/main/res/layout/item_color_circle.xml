<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="44dp"
    android:layout_height="44dp"
    android:layout_marginEnd="12dp">

    <!-- 항상 보이는 검은 테두리 -->
    <View
        android:id="@+id/v_border"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_border_black" />

    <!-- 선택된 경우만 보이는 추가 링(강조) -->
    <View
        android:id="@+id/v_stroke"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_stroke_selected"
        android:visibility="gone" />

    <!-- 내부 채움(테두리 없음) + tint로 색 적용 -->
    <View
        android:id="@+id/v_circle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_circle_fill" />
</FrameLayout>
