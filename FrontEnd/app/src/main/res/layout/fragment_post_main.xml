<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/postMainContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingBottom="0dp">

    <!-- 상단 제목 (무신사 톤: 16sp bold) -->
    <TextView
        android:id="@+id/tvPostMainTitle"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="스레드"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0A0F18"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnCreatePost"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 게시글 생성 버튼 (톤 통일: 40dp / 12sp bold / main_color) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreatePost"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="스레드 생성"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:stateListAnimator="@null"
        app:backgroundTint="@color/main_color"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 검색 영역 (입력 톤 통일: 높이 32dp / bg_login_input) -->
    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_login_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvPostMainTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etKeyword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="검색어"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:textSize="@dimen/text_input"
            android:textColor="#0A0F18"
            android:textColorHint="#9E9E9E"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="검색"
            android:src="@android:drawable/ic_menu_search"
            android:padding="6dp" />
    </LinearLayout>

    <!-- 정렬/필터: 기능 유지(라디오 4개), 톤만 정리 -->
    <RadioGroup
        android:id="@+id/rgPostOption"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/llSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/rbLatest"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:checked="true"
            android:text="최신순"
            android:textSize="12sp"
            android:textColor="#0A0F18"
            android:buttonTint="@color/main_color"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <RadioButton
            android:id="@+id/rbPopular"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:text="추천순"
            android:textSize="12sp"
            android:textColor="#0A0F18"
            android:buttonTint="@color/main_color"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <RadioButton
            android:id="@+id/rbWritten"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:text="나의 게시글"
            android:textSize="12sp"
            android:textColor="#0A0F18"
            android:buttonTint="@color/main_color"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <RadioButton
            android:id="@+id/rbLiked"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="좋아요한 게시글"
            android:textSize="12sp"
            android:textColor="#0A0F18"
            android:buttonTint="@color/main_color"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />
    </RadioGroup>

    <!-- 게시글 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPostList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@+id/rgPostOption"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_post_card" />

</androidx.constraintlayout.widget.ConstraintLayout>
