<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/postMainContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">
    <!--tools:context=".homeActivity.post.PostMainFragment">-->

    <!-- 상단 제목 -->
    <TextView
        android:id="@+id/tvPostMainTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="게시판 목록"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btnCreatePost"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 게시글 생성 버튼 -->
    <Button
        android:id="@+id/btnCreatePost"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="게시글 생성"
        android:backgroundTint="@color/main_color"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 검색 영역 -->
    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="#E0E0E0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvPostMainTitle">

        <EditText
            android:id="@+id/etKeyword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="검색어"
            android:inputType="text"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@null"
            android:contentDescription="검색"
            android:src="@android:drawable/ic_menu_search" />

    </LinearLayout>

    <!-- 정렬/필터: 4개 중 1개만 선택 (1x4, 기본 최신순) -->
    <RadioGroup
        android:id="@+id/rgPostOption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/llSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/rbLatest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:checked="true"
            android:text="최신순"
            android:textSize="10sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <RadioButton
            android:id="@+id/rbPopular"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:text="추천순"
            android:textSize="10sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"/>

        <RadioButton
            android:id="@+id/rbWritten"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="나의 게시글"
            android:textSize="10sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <RadioButton
            android:id="@+id/rbLiked"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="좋아요한 게시글"
            android:textSize="10sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"/>

    </RadioGroup>

    <!-- 게시글 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPostList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rgPostOption"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/item_post_card" />

</androidx.constraintlayout.widget.ConstraintLayout>
