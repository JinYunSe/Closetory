<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/svPostCreate"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/postCreateRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 제목 라벨 (새 id 추가: 기능 영향 없음) -->
        <TextView
            android:id="@+id/tvTitleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제목"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0A0F18"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 제목 입력 (id 유지: etTitle) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTitle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvTitleLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="제목을 30자 이내로 작성해주세요."
                android:inputType="text"
                android:maxLength="30"
                android:maxLines="1"
                android:singleLine="true"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#0A0F18"
                android:textColorHint="#9E9E9E"
                android:padding="4dp" />
        </com.google.android.material.textfield.TextInputLayout>

<!--        <TextView-->
<!--            android:id="@+id/tvCreatedAt"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="8dp"-->
<!--            android:text="등록 시간"-->
<!--            android:textSize="12sp"-->
<!--            android:textColor="#0A0F18"-->
<!--            android:visibility="gone"-->
<!--            app:layout_constraintTop_toBottomOf="@id/etTitle"-->
<!--            app:layout_constraintEnd_toEndOf="parent" />-->

        <!-- 사진 라벨 (새 id 추가: 기능 영향 없음) -->
        <TextView
            android:id="@+id/tvMainPhotoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="대표 사진"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0A0F18"
            app:layout_constraintTop_toBottomOf="@id/tilTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 메인 사진 영역 (비율로 높이 고정: 지금처럼 4:5 유지하면 항상 동일하게 나옴) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivMainPhoto"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlayClosetoryMediumRounded"
            app:layout_constraintTop_toBottomOf="@id/tvMainPhotoLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="4:5" />


        <TextView
            android:id="@+id/tvMainPhotoHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="대표 사진을 추가해주세요."
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0A0F18"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintTop_toTopOf="@id/ivMainPhoto"
            app:layout_constraintBottom_toBottomOf="@id/ivMainPhoto"
            app:layout_constraintStart_toStartOf="@id/ivMainPhoto"
            app:layout_constraintEnd_toEndOf="@id/ivMainPhoto" />

        <!-- 옷 요소 라벨 (id 유지: tvItemsLabel) -->
        <TextView
            android:id="@+id/tvItemsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="옷 정보"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0A0F18"
            app:layout_constraintTop_toBottomOf="@id/ivMainPhoto"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 옷요소 RecyclerView (id 유지) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/tvItemsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAddItem"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <TextView
            android:id="@+id/tvNoClothes"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_login_input"
            android:gravity="center"
            android:text="옷을 등록해주세요."
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvItemsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAddItem"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <!-- 옷 요소 등록 버튼 (id 유지) -->
        <ImageButton
            android:id="@+id/btnAddItem"
            android:layout_width="64dp"
            android:layout_height="90dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_login_input"
            android:contentDescription="옷요소 추가"
            android:src="@drawable/ic_add_24"
            android:tint="#0A0F18"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvItemsLabel" />

        <!-- 게시글 라벨 (id 유지: tvContentLabel) -->
        <TextView
            android:id="@+id/tvContentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="게시글"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0A0F18"
            app:layout_constraintTop_toBottomOf="@id/btnAddItem"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 내용 입력 (id 유지: etContent) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContent"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="4dp"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvContentLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:gravity="top"
                android:hint="게시글 작성해주세요."
                android:inputType="textMultiLine"
                android:maxLines="50"
                android:scrollbars="vertical"
                android:textSize="12sp"
                android:textColor="#0A0F18"
                android:textColorHint="#9E9E9E"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 등록 버튼 (id 유지: btnRegistrationPost) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrationPost"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:text="등록"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:padding="4dp"
            app:backgroundTint="@color/main_color"
            app:cornerRadius="8dp"
            app:rippleColor="#66FFFFFF"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:layout_constraintTop_toBottomOf="@id/tilContent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
