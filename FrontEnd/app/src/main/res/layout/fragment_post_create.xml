<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/svPostCreate"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/postCreateRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 제목 -->
        <EditText
            android:id="@+id/etTitle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_gray_border"
            android:gravity="center"
            android:hint="제목"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 작성자 / 등록 시간 (등록 화면에선 의미 없으면 GONE) -->
        <TextView
            android:id="@+id/tvWriter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="작성자"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintEnd_toStartOf="@id/tvCreatedAt" />

        <TextView
            android:id="@+id/tvCreatedAt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="등록 시간"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 메인 사진 영역 (클릭하면 갤러리) -->
        <ImageView
            android:id="@+id/ivMainPhoto"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_gray_box"
            android:contentDescription="메인 사진"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- (선택) 사진 영역 중앙에 안내 텍스트 -->
        <TextView
            android:id="@+id/tvMainPhotoHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진"
            android:textSize="22sp"
            android:textStyle="bold"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintTop_toTopOf="@id/ivMainPhoto"
            app:layout_constraintBottom_toBottomOf="@id/ivMainPhoto"
            app:layout_constraintStart_toStartOf="@id/ivMainPhoto"
            app:layout_constraintEnd_toEndOf="@id/ivMainPhoto" />

        <!-- 옷요소 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/ivMainPhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAddItem"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <!-- + 버튼 (클릭하면 갤러리에서 옷요소 사진 추가) -->

        <!-- 게시글 내용 -->

        <!-- 등록 버튼 -->
        <ImageButton
            android:id="@+id/btnAddItem"
            android:layout_width="64dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_gray_border"
            android:contentDescription="옷요소 추가"
            android:src="@drawable/ic_add_24"
            android:tint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivMainPhoto" />

        <EditText
            android:id="@+id/etContent"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_gray_border"
            android:gravity="top"
            android:hint="게시글 작성"
            android:textStyle="bold"
            android:inputType="textMultiLine"
            android:scrollbars="vertical"
            android:maxLines="50"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvItems" />

        <Button
            android:id="@+id/btnRegistrationPost"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="등록"
            android:backgroundTint="@color/main_color"
            app:layout_constraintTop_toBottomOf="@id/etContent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
