<?xml version="1.0" encoding="utf-8"?>

<!-- 로그인 페이지 xml -->


<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id = "@+id/loginContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_margin="20dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <TextView
        android:id="@+id/tvLoginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="36sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etLoginId"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="아이디"
        android:singleLine="true"
        android:maxLines="1"
        android:inputType="text"
        android:background="#E0E0E0"
        android:padding="16dp"
        android:layout_marginTop="40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="비밀번호"
            android:inputType="textPassword"
            android:background="@null"
            android:padding="16dp" />

        <Button
            android:id="@+id/btnToggleLoginPassword"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:text="👁"
            android:backgroundTint="@color/main_color"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="로그인"
        android:backgroundTint="@color/main_color"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/btnGoogleLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="구글 로그인"
        android:backgroundTint="@color/main_color"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnKakaoLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="카카오 로그인"
        android:backgroundTint="@color/main_color"
        android:layout_marginTop="8dp"/>

    <LinearLayout
        android:id = "@+id/footerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:id = "@+id/footerSignupContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvNoId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="계정이 없으신가요?"
                android:textSize="14sp"
                android:textColor="#000000"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp" />
            <TextView
                android:id="@+id/tvNoIdToSignup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원가입"
                android:textSize="14sp"
                android:textColor="#000000"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/footerFindContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFindId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="아이디 찾기"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvFindPw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="비밀번호 찾기"
                android:textColor="#000000"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
