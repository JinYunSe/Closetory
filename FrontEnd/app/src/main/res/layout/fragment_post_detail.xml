<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/postDetailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvPostDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutPostDetailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 제목 (id 유지) -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center"
                android:text="게시글 제목"
                android:background="@drawable/bg_login_input"
                android:textColor="@color/main_color"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 작성자/통계 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:layout_gravity="center_vertical"
                android:layout_marginTop="8dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="프로필 사진"
                    android:src="@drawable/ic_profile_default"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="작성자"
                    android:textColor="@color/main_color"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/ivProfile"
                    app:layout_constraintTop_toTopOf="@id/ivProfile"
                    app:layout_constraintBottom_toBottomOf="@id/ivProfile" />

                <!-- 우측: 조회수/좋아요 -->
                <LinearLayout
                    android:id="@+id/layoutStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center|end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivProfile"
                    app:layout_constraintBottom_toBottomOf="@id/ivProfile">

                    <!-- 조회수 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="10dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivViewsIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:tint="@color/black"
                            android:contentDescription="조회수 아이콘"
                            android:src="@drawable/ic_eye" />

                        <TextView
                            android:id="@+id/tvViews"
                            style="@style/TextPostSmallInfoLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="0"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <!-- 좋아요 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginStart="10dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivLikeIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="좋아요 아이콘"
                            android:src="@drawable/heart_empty" />

                        <TextView
                            android:id="@+id/tvLikes"
                            style="@style/TextPostSmallInfoLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="0"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 게시글 사진 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_login_input"
                android:padding="1dp">

                <!-- ✅ FIX: 0dp + ratio면 top/bottom 제약을 완성시켜야 함 -->
                <FrameLayout
                    android:id="@+id/boxPostPhoto"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_login_input"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="4:5">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPostPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@android:color/white"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlayClosetoryMediumRounded" />

                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 옷 정보 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="옷 정보"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/main_color" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClothes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"/>

            <TextView
                android:id="@+id/tvNoClothes"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_input"
                android:gravity="center"
                android:text="옷 정보가 없습니다."
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- 게시글 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="게시글"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/main_color" />

            <!-- 본문 (id 유지) -->
            <TextView
                android:id="@+id/tvContent"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_input"
                android:text="게시글"
                android:textColor="@color/main_color"
                android:textSize="12sp"
                android:padding="12dp"
                android:scrollbars="vertical"
                android:overScrollMode="ifContentScrolls"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- 댓글 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="댓글"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/main_color" />

            <!-- 댓글 입력 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutCommentInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilComment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnCommentSubmit"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:maxHeight="120dp"
                        android:background="@drawable/bg_login_input"
                        android:hint="댓글을 입력하세요"
                        android:inputType="textMultiLine"
                        android:gravity="center|start"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:textSize="12sp"
                        android:textColor="@color/main_color"
                        android:textColorHint="#9E9E9E"
                        android:scrollbars="vertical"
                        android:overScrollMode="ifContentScrolls" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCommentSubmit"
                    android:layout_width="96dp"
                    android:layout_height="40dp"
                    android:text="댓글 등록"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/main_color"
                    app:cornerRadius="8dp"
                    app:rippleColor="#1A000000"
                    android:stateListAnimator="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tilComment"
                    app:layout_constraintBottom_toBottomOf="@id/tilComment" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <!-- 수정/삭제 버튼 영역 (id 유지) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutPostActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdate"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:text="수정"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/main_color"
                    app:cornerRadius="8dp"
                    app:rippleColor="#1A000000"
                    android:stateListAnimator="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnDelete"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintHorizontal_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:text="삭제"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/gray_500"
                    app:cornerRadius="8dp"
                    app:rippleColor="#1A000000"
                    android:stateListAnimator="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:layout_constraintStart_toEndOf="@id/btnUpdate"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnUpdate"
                    app:layout_constraintBottom_toBottomOf="@id/btnUpdate"
                    app:layout_constraintHorizontal_weight="1" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
