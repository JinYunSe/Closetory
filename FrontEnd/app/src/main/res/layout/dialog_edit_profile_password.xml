<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_edit_profile_password.xml -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 새 비밀번호 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="새 비밀번호 입력"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:padding="4dp"
                android:paddingEnd="36dp"
                android:singleLine="true"
                android:maxLines="1"
                android:textColor="#0A0F18"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnToggleNewPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_eye"
            android:contentDescription="새 비밀번호 보기/숨기기" />
    </FrameLayout>

    <!-- 새 비밀번호 확인 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:boxBackgroundMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNewPasswordConfirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_login_input"
                android:hint="새 비밀번호 확인"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:padding="4dp"
                android:paddingEnd="36dp"
                android:singleLine="true"
                android:maxLines="1"
                android:textColor="#0A0F18"
                android:textColorHint="#9E9E9E" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnToggleNewPasswordConfirm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_eye"
            android:contentDescription="새 비밀번호 확인 보기/숨기기" />
    </FrameLayout>

    <!-- 확인 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmChangePassword"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:text="확인"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:padding="4dp"
        app:backgroundTint="@color/main_color"
        app:cornerRadius="8dp"
        app:rippleColor="#1A000000"
        android:stateListAnimator="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
