<?xml version="1.0" encoding="utf-8"?>

<!-- dialog_edit_profile_password.xml -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 현재 비밀번호 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etCurrentPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="현재 비밀번호 입력"
            android:inputType="textPassword"
            android:background="@null"
            android:padding="12dp"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btnToggleCurrentPassword"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="@null"
            android:src="@drawable/ic_eye"
            android:contentDescription="현재 비밀번호 보기/숨기기" />
    </LinearLayout>

    <!-- 새 비밀번호 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="새 비밀번호 입력"
            android:inputType="textPassword"
            android:background="@null"
            android:padding="12dp"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btnToggleNewPassword"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="@null"
            android:src="@drawable/ic_eye"
            android:contentDescription="새 비밀번호 보기/숨기기" />
    </LinearLayout>

    <!-- 새 비밀번호 확인 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etNewPasswordConfirm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="새 비밀번호 확인"
            android:inputType="textPassword"
            android:background="@null"
            android:padding="12dp"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btnToggleNewPasswordConfirm"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="@null"
            android:src="@drawable/ic_eye"
            android:contentDescription="새 비밀번호 확인 보기/숨기기" />
    </LinearLayout>

    <!-- 확인 버튼 -->
    <Button
        android:id="@+id/btnConfirmChangePassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/main_color"
        android:text="확인"
        android:textColor="#000000" />

</LinearLayout>
