<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="1dp"
        android:layout_marginTop="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="&lt;"
            android:textColor="#000000"
            android:textSize="22sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="0.8"
                android:gravity="center|end"
                android:text="@string/styling_owned_only"
                android:textColor="#000000"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleX="0.80"
                android:scaleY="0.80"
                android:showText="false"
                android:switchMinWidth="48dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector" />

        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragme_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_login_input"
        android:paddingBottom="20dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="85dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView
            android:id="@+id/vv_ai_loading"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/styling_ai_fitting_desc"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/styling_close"
                android:src="@drawable/ic_cancel" />

            <ImageView
                android:id="@+id/vv_ai_fitting"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:visibility="gone" />

        </FrameLayout>
    </FrameLayout>

    <include
        android:id="@+id/closet_list"
        layout="@layout/include_closet_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_register"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_login_button_black"
            android:text="@string/styling_ai_button"
            android:textColor="@color/styling_text_color"
            app:icon="@drawable/img_ai_logo"
            app:iconGravity="textStart"
            app:iconSize="18dp" />

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_reset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            android:text="@string/styling_reset"
            android:textColor="#000000"
            android:textStyle="bold"
            android:translationZ="0dp"
            app:backgroundTint="@null" />

    </LinearLayout>
</LinearLayout>
