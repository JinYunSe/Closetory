<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            android:layout_width="55dp"
            android:layout_height="48dp"
            android:backgroundTint="@color/white"
            android:text="&lt;"
            android:textColor="#A6DAF4"
            app:backgroundTint="@android:color/white"
            app:strokeWidth="0.8dp"
            app:strokeColor="#A6DAF4"
            app:cornerRadius="12dp"

            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingVertical="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_virtualfitting"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="✨ AI가상 생성"
            android:textColor="#A6DAF4"

            app:backgroundTint="@android:color/white"
            app:strokeWidth="0.8dp"
            app:strokeColor="#A6DAF4"
            app:cornerRadius="12dp"

            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingVertical="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            />



        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_switch_group">

            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="모든 옷"
                android:textColor="#A6DAF4"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:showText="false"
                android:switchMinWidth="48dp"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#e9ecef">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_slot_empty"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/gray_500">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="AI 가상 피팅 결과" />

            <!-- AI 이미지 닫기 버튼 -->
            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_cancel"
                android:contentDescription="닫기" />

            <!-- 로딩 인디케이터 -->
            <ProgressBar
                android:id="@+id/progress_ai_fitting"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="상의"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_top_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="하의"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_bottom_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="아우터"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_outer"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="악세사리"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_acc_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="가방"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_bag_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="신발"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_shoes_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_cloth" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_register"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="등록"
            android:backgroundTint="#A6DAF4"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_reset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="초기화"
            android:backgroundTint="#A6DAF4"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</LinearLayout>