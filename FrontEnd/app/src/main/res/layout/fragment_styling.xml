<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginStart="1dp"
        android:layout_marginTop="1dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="&lt;"
            android:textSize="22sp"
            android:textColor="#000000"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:includeFontPadding="false"/>


        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <!-- ⭐ AI 가상피팅 버튼 삭제됨 (등록 버튼으로 통합) -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            >

            <TextView
                android:id="@+id/tv_switch_owned_only"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="0.8"
                android:gravity="center|end"
                android:text="모든 옷"
                android:textColor="#000000"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_switch_owned_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:showText="false"
                android:switchMinWidth="48dp"
                android:scaleX="0.80"
                android:scaleY="0.80"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>
    </LinearLayout>

    <!-- ⭐ 슬롯 영역 (VideoView 추가됨) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_login_input">

        <!-- ⭐ VideoView 로딩 애니메이션 추가 (AI 페이지와 동일) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_slots"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <FrameLayout
                android:id="@+id/slot_top"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_slot_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_top"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_outer"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintEnd_toStartOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_outer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_outer"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_acc"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_top"
                app:layout_constraintTop_toTopOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_acc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_acc"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bottom"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_top">

                <ImageView
                    android:id="@+id/iv_slot_bottom"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bottom"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_bag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/slot_bottom"
                app:layout_constraintTop_toTopOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_bag"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_bag"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/slot_shoes"
                android:layout_width="85dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/slot_bottom">

                <ImageView
                    android:id="@+id/iv_slot_shoes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_login_input"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btn_remove_shoes"
                    android:layout_width="25dp"
                    android:layout_height="35dp"
                    android:layout_gravity="top|end"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_cancel"
                    android:visibility="gone" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <VideoView
            android:id="@+id/vv_ai_loading"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- 가상피팅 결과 팝업 -->
        <FrameLayout
            android:id="@+id/layout_ai_fitting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/gray_500">

            <ImageView
                android:id="@+id/iv_ai_fitting_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="AI 가상 피팅 결과" />

            <ImageButton
                android:id="@+id/btn_close_ai_fitting"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_cancel"
                android:contentDescription="닫기" />

            <!-- ⭐ 가상피팅 팝업 로딩 (별도) -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_fill"
                android:visibility="gone"
                android:id="@+id/layout_ai_loading_circle">

                <ProgressBar
                    android:id="@+id/vv_ai_fitting"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:indeterminate="true" />
            </FrameLayout>
        </FrameLayout>

    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="상의"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_top_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="하의"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_bottom_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="아우터"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_outer"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="소품류"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_acc_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="가방"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_bag_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="신발"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lv_shoes_cloth"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_clothes" />

        </LinearLayout>
    </ScrollView>

    <!-- ⭐ 버튼 영역 (AI 페이지와 동일한 스타일) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_register"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="AI 가상피팅"
            android:background="@drawable/bg_login_button_black"
            android:textColor="@color/styling_text_color"
            app:icon="@drawable/img_ai_logo"
            app:iconSize="18dp"
            app:iconGravity="textStart"/>

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <!-- 초기화 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_styling_reset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_input"
            app:backgroundTint="@null"
            android:text="초기화"
            android:textColor="#000000"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"

            android:elevation="0dp"
            android:translationZ="0dp"
            android:stateListAnimator="@null"
            />
    </LinearLayout>

</LinearLayout>