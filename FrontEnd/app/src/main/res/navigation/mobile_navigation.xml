<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.ssafy.closetory.homeActivity.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_closet"
        android:name="com.ssafy.closetory.homeActivity.closet.ClosetFragment"
        android:label="@string/title_closet"
        tools:layout="@layout/fragment_closet" />


    <fragment
        android:id="@+id/navigation_styling"
        android:name="com.ssafy.closetory.homeActivity.styling.StylingFragment"
        android:label="@string/title_styling"
        tools:layout="@layout/fragment_styling" />

    <fragment
        android:id="@+id/navigation_ai_styling"
        android:name="com.ssafy.closetory.homeActivity.aiStyling.AiStylingFragment"
        android:label="@string/title_styling"
        tools:layout="@layout/fragment_ai_styling">

        <!-- AI 화면에서 "직접 코디 생성" 버튼 누르면 StylingFragment로 이동하는 코드-->
        <action
            android:id="@+id/action_ai_to_manual_styling"
            app:destination="@id/navigation_styling" />
    </fragment>

    <fragment
        android:id="@+id/navigation_my_page"
        android:name="com.ssafy.closetory.homeActivity.myPage.MyPageFragment"
        android:label="@string/title_my_page"
        tools:layout="@layout/fragment_my_page" />

    <fragment
        android:id="@+id/navigation_add_close"
        android:name="com.ssafy.closetory.homeActivity.addClose.AddClothFragment"
        android:label="@string/title_add_cloth"
        tools:layout="@layout/fragment_add_cloth" />

    <fragment
        android:id="@+id/navigation_cody_repository"
        android:name="com.ssafy.closetory.homeActivity.codyRepository.CodyRepositoryFragment"
        android:label="CodyRepository"
        tools:layout="@layout/fragment_cody_repository" />


</navigation>
