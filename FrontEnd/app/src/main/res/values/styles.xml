<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom font 적용 -->
    <style name="CustomTextViewFontStyle"
        parent="@android:style/Widget.DeviceDefault.TextView">

        <item name="android:fontFamily">@font/font_gumiromance</item>

    </style>

    <style name="ClosetTabText" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:maxLines">2</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">none</item>
        <item name="android:textSize">10sp</item>
    </style>

    <!-- 태그 버튼 스타일 지정 -->
    <style name="Widget.Closetory.TagButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <!-- 모양 -->
        <item name="cornerRadius">10dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/tag_stroke_selector</item>

        <!-- 상태별 색 -->
        <item name="backgroundTint">@color/tag_bg_selector</item>
        <item name="android:textColor">@color/tag_text_selector</item>

        <!-- 눌림 효과 -->
        <item name="rippleColor">#1A000000</item>

        <!-- MaterialButton 기본 크기/여백 영향 최소화 -->
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <!-- 사진 테두리 영역 -->
    <style name="ShapeAppearanceOverlayClosetoryMediumRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>

    </style>

    <!-- 사진 테두리 바운더리 선 -->
    <style name="WidgetClosetoryPhotoBox">
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/gray_300</item>
    </style>



    <!-- 원형 프로필 이미지용 ShapeAppearance -->
    <style name="ShapeAppearance.Circle"
        parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 달력 -->
    <style name="CalendarDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- 게시글 상세 메타 라벨(조회수, 좋아요 수 같은 텍스트) -->
    <style name="TextPostSmallInfoLabel">
        <item name="android:textSize">8sp</item>
        <item name="android:textColor">#666666</item>
    </style>
</resources>